{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.ts"
    }
  ],
  "functions": {
    "server.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "regions": ["iad1"]
    }
  }
}